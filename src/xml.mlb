(* MLB for the sml-xml library: the vendored sml-unicode core plus the xml
 * sources. Consumers reference this file.
 *
 * The dependency .mlb file is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples) can `open Unicode` alongside Xml. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-unicode/sml-unicode.mlb
xml.sig
xml.sml
