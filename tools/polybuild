#!/bin/sh
#
# polybuild - build an executable from a flat .mlb file using Poly/ML.
#
# This is a small, self-contained alternative to cannam/sml-buildscripts'
# polybuild (which depends on a companion smlbuild-include.sh). It only
# understands the portable subset of the MLB format that this project uses:
# a file is a newline-separated list of paths, where
#   - lines beginning with $(...) (e.g. the Basis library) are ignored,
#     since Poly/ML loads the Basis automatically;
#   - lines ending in .mlb are expanded recursively (relative to the
#     including file's directory);
#   - lines ending in .sml/.sig/.fun are `use`d in order, EXCEPT a file
#     named main.sml, which is skipped in export mode: by convention it only
#     contains the MLton top-level invocation, and Poly/ML uses the exported
#     `main` instead;
#   - blank lines and (* ... *) comments are ignored, including comment
#     blocks spanning multiple lines (no nesting).
#
# The program is expected to define `main : unit -> unit`, which Poly/ML
# exports as the executable entry point.
#
# Usage: tools/polybuild -o OUTPUT FILE.mlb
#        tools/polybuild -r FILE.mlb
#
# -r runs the program instead of linking it: each source is `use`d in order
# and its top-level effects execute immediately. This suits demo scripts
# (examples/demo.sml). In run mode main.sml is NOT skipped: for main-style
# demos it is exactly the file whose `val () = main ()` runs the program.

set -eu

out=""
mlb=""
runmode=0

while [ $# -gt 0 ]; do
    case "$1" in
        -o) shift; out="$1" ;;
        -r) runmode=1 ;;
        *)  mlb="$1" ;;
    esac
    shift
done

if [ -z "$mlb" ] || { [ "$runmode" = 0 ] && [ -z "$out" ]; }; then
    echo "Usage: polybuild -o OUTPUT FILE.mlb | polybuild -r FILE.mlb" 1>&2
    exit 2
fi

# Strip /* ... */-free SML comments (* ... *) on a single line, then trim.
strip_line() {
    printf '%s' "$1" | sed -e 's/(\*.*\*)//g' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

# Recursively print the ordered list of source files referenced by an .mlb.
# Each recursive call runs in a subshell so its $_dir does not clobber the
# caller's (POSIX sh has no local variables).
expand_mlb() (
    _mlb="$1"
    _dir=$(dirname "$_mlb")
    _incomment=0
    while IFS= read -r _raw || [ -n "$_raw" ]; do
        if [ "$_incomment" = 1 ]; then
            case "$_raw" in
                *'*)'*) _incomment=0; _raw=${_raw#*\*\)} ;;
                *) continue ;;
            esac
        fi
        _line=$(strip_line "$_raw")
        case "$_line" in
            *'(*'*) _incomment=1; _line=$(strip_line "${_line%%\(\**}") ;;
        esac
        [ -z "$_line" ] && continue
        case "$_line" in
            \$\(*) continue ;;                      # basis / path vars: skip
            *.mlb) expand_mlb "$_dir/$_line" ;;     # nested basis: recurse
            *.sml|*.sig|*.fun)
                case "$_line" in
                    main.sml|*/main.sml)
                        # MLton entry shim: skipped when exporting main, kept
                        # in run mode (it is what invokes the program there).
                        if [ "${POLYBUILD_KEEP_MAIN:-0}" = 1 ]; then
                            _p="$_dir/$_line"
                            _pd=$(CDPATH= cd "$(dirname "$_p")" 2>/dev/null && pwd)
                            if [ -n "$_pd" ]; then
                                printf '%s\n' "$_pd/$(basename "$_p")"
                            else
                                printf '%s\n' "$_p"
                            fi
                        fi ;;
                    *)
                        # Canonicalize so the same file reached via different
                        # relative prefixes (diamond deps) dedups downstream.
                        _p="$_dir/$_line"
                        _pd=$(CDPATH= cd "$(dirname "$_p")" 2>/dev/null && pwd)
                        if [ -n "$_pd" ]; then
                            printf '%s\n' "$_pd/$(basename "$_p")"
                        else
                            printf '%s\n' "$_p"
                        fi ;;
                esac ;;
            *) continue ;;
        esac
    done < "$_mlb"
)

# Files reachable through more than one nested .mlb (diamond dependencies,
# common once libraries vendor shared deps) must be `use`d only once: each
# opaque (:>) ascription elaborates to a fresh type, so a second `use` of the
# same source would shadow the first with incompatible types. We therefore
# deduplicate the expanded file list, keeping first occurrence (which is in
# dependency order).

# Run mode: `use` everything (top-level effects execute) and stop.
if [ "$runmode" = 1 ]; then
    POLYBUILD_KEEP_MAIN=1
    export POLYBUILD_KEEP_MAIN
    expand_mlb "$mlb" | awk '!seen[$0]++' | while IFS= read -r f; do
        printf 'val () = use "%s";\n' "$f"
    done | poly -q --error-exit
    exit 0
fi

tmpobj="${TMPDIR:-/tmp}/polybuild.$$.o"
trap 'rm -f "$tmpobj"' EXIT

# Compile + export the object file via the Poly/ML REPL.
{
    expand_mlb "$mlb" | awk '!seen[$0]++' | while IFS= read -r f; do
        printf 'val () = use "%s";\n' "$f"
    done
    printf 'val () = PolyML.export("%s", main);\n' "$tmpobj"
} | poly -q --error-exit

# Link the object into an executable.
#
# We do the link ourselves rather than calling `polyc -o`, because some
# packaged `polyc` scripts quote the whole compiler-plus-flags string as a
# single command word (e.g. LINK="clang++ -std=gnu++11"), which fails with
# "command not found" on a correct install. We read the relevant settings
# out of the installed `polyc` and invoke the linker with word splitting.
polyc_path=$(command -v polyc)
libdir=$(sed -n 's/^LIBDIR="\(.*\)"/\1/p' "$polyc_path" | head -n1)
link=$(sed -n 's/^LINK="\(.*\)"/\1/p' "$polyc_path" | head -n1)
: "${link:=c++}"
: "${libdir:=/usr/local/lib}"

# On recent macOS toolchains the new linker can fail on Poly/ML's exported
# object with "LINKEDIT overlap"; the classic linker handles it. Add the
# flag only on Darwin so other platforms are unaffected.
extra_ldflags=""
case "$(uname -s)" in
    Darwin) extra_ldflags="-Wl,-ld_classic" ;;
esac

# shellcheck disable=SC2086  # intentional word splitting on $link/$extra_ldflags
if ! $link "$tmpobj" -o "$out" $extra_ldflags \
        -L"$libdir" -Wl,-rpath,"$libdir" -lpolymain -lpolyml; then
    # Fall back to polyc's own linking if the manual link fails (e.g. a
    # differently-packaged polyc whose settings we couldn't parse).
    echo "polybuild: manual link failed, falling back to polyc -o" 1>&2
    polyc -o "$out" "$tmpobj"
fi
